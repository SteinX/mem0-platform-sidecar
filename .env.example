# Sidecar storage. SQLite is fine for local/dev; use a SQLAlchemy Postgres URL
# for containerized shared deployments.
MEM0_SIDECAR_DATABASE_URL=sqlite:////data/mem0_sidecar.sqlite3

# Required for Docker deployments: set this to the Mem0 OSS REST base URL as
# seen from the sidecar container. Examples:
# - Same compose network: http://mem0:8000
# - Another Docker network alias: http://mem0-api:8000
# - Host service on Docker Desktop: http://host.docker.internal:8000
MEM0_SIDECAR_MEM0_BASE_URL=http://mem0:8000

# Dashboard overlay Next.js server route proxy target.
# This is read by the dashboard runtime, not by the sidecar service.
SIDECAR_INTERNAL_API_URL=http://mem0-platform-sidecar:8765

# Optional Mem0 OSS auth. Use X-API-Key by default, or switch to
# Authorization/Bearer for gateways that expect bearer tokens.
MEM0_SIDECAR_MEM0_API_KEY=
MEM0_SIDECAR_MEM0_API_KEY_HEADER_NAME=X-API-Key
MEM0_SIDECAR_MEM0_API_KEY_PREFIX=

# Optional JSON object for static headers sent to Mem0 OSS or an API gateway.
MEM0_SIDECAR_MEM0_EXTRA_HEADERS={}

# Mem0 OSS REST paths. Keep the defaults for upstream-compatible Mem0 OSS.
# If a gateway mounts Mem0 under a prefix, prefer putting that prefix in
# MEM0_SIDECAR_MEM0_BASE_URL.
MEM0_SIDECAR_MEM0_MEMORIES_PATH=/memories
MEM0_SIDECAR_MEM0_SEARCH_PATH=/search

# Upstream timeout and TLS behavior.
MEM0_SIDECAR_MEM0_REQUEST_TIMEOUT_SECONDS=30
MEM0_SIDECAR_MEM0_CONNECT_TIMEOUT_SECONDS=30
MEM0_SIDECAR_MEM0_VERIFY_TLS=true
MEM0_SIDECAR_MEM0_CA_BUNDLE=

# Default control-plane project scope.
MEM0_SIDECAR_DEFAULT_PROJECT_ID=default

# Safety net for clients that still write directly to Mem0 OSS. Prefer routing
# writers through the sidecar; this bounded mirror preserves each source app_id.
MEM0_SIDECAR_DIRECT_WRITE_SYNC_ENABLED=false
MEM0_SIDECAR_DIRECT_WRITE_SYNC_INTERVAL_SECONDS=60
MEM0_SIDECAR_DIRECT_WRITE_SYNC_SCAN_LIMIT=5000
MEM0_SIDECAR_DIRECT_WRITE_SYNC_LEGACY_CAP=1000
MEM0_SIDECAR_DIRECT_WRITE_SYNC_DEFAULT_APP_ID=default

# Service logging and correlation.
MEM0_SIDECAR_LOG_LEVEL=INFO
MEM0_SIDECAR_LOG_FORMAT=json
MEM0_SIDECAR_REQUEST_ID_HEADER=X-Request-ID
