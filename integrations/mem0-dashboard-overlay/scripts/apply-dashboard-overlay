#!/usr/bin/env python3
import json
import shutil
import sys
from pathlib import Path


def looks_like_dashboard_checkout(dashboard_dir: Path) -> bool:
    package_json = dashboard_dir / "package.json"
    if not package_json.exists():
        return False
    try:
        package_data = json.loads(package_json.read_text())
    except json.JSONDecodeError:
        return False
    scripts = package_data.get("scripts")
    return (
        package_data.get("name") == "mem0-dashboard"
        and isinstance(scripts, dict)
        and isinstance(scripts.get("typecheck"), str)
    )


def main() -> int:
    if len(sys.argv) != 2:
        print("usage: apply-dashboard-overlay <dashboard-dir>", file=sys.stderr)
        return 2

    overlay_root = Path(__file__).resolve().parents[1]
    dashboard_dir = Path(sys.argv[1]).resolve()
    if not looks_like_dashboard_checkout(dashboard_dir):
        print(
            f"{dashboard_dir} does not look like a Mem0 dashboard checkout",
            file=sys.stderr,
        )
        return 1

    manifest = json.loads((overlay_root / "manifest.json").read_text())
    source_root = overlay_root / "overlays"

    for relative in manifest["files"]:
        source = source_root / relative
        target = dashboard_dir / relative
        if not source.exists():
            print(f"overlay source missing: {source}", file=sys.stderr)
            return 1
        target.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(source, target)
        print(f"copied {relative}")

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
