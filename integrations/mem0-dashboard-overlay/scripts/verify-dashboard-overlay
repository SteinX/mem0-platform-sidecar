#!/usr/bin/env python3
import json
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path

LOCKED_TARGETS = [
    "src/app/(root)/dashboard/categories/page.tsx",
    "src/app/(root)/dashboard/export/page.tsx",
]
MAIN_NAV = "src/app/(root)/dashboard/components/main-nav.tsx"
CATEGORIES_PAGE = "src/app/(root)/dashboard/categories/page.tsx"
CATEGORY_EDITOR_DRAWER = (
    "src/app/(root)/dashboard/categories/category-editor-drawer.tsx"
)
EXPORT_PAGE = "src/app/(root)/dashboard/export/page.tsx"
SIDECAR_PROXY = "src/utils/sidecar-proxy.ts"
SIDECAR_ROUTE = "src/app/api/sidecar/[...path]/route.ts"
DEFAULT_PNPM_PACKAGE = "pnpm@10.34.2"


def npm_exec_pnpm_package(dashboard_dir: Path) -> str:
    package_json = dashboard_dir / "package.json"
    if not package_json.exists():
        return DEFAULT_PNPM_PACKAGE

    package_data = json.loads(package_json.read_text())
    package_manager = package_data.get("packageManager")
    if isinstance(package_manager, str) and package_manager.startswith("pnpm@"):
        return package_manager
    return DEFAULT_PNPM_PACKAGE


def typecheck_command(dashboard_dir: Path) -> list[str]:
    if shutil.which("pnpm"):
        return ["pnpm", "typecheck"]
    if shutil.which("npm"):
        return [
            "npm",
            "exec",
            "--yes",
            npm_exec_pnpm_package(dashboard_dir),
            "--",
            "typecheck",
        ]
    raise FileNotFoundError("Neither pnpm nor npm is available on PATH")


def proxy_harness_command(overlay_root: Path, dashboard_dir: Path) -> list[str]:
    node = shutil.which("node")
    if not node:
        raise FileNotFoundError("Node.js is not available on PATH")
    return [
        node,
        str(overlay_root / "scripts" / "test-sidecar-proxy.cjs"),
        str(dashboard_dir),
    ]


def category_schema_harness_command(
    overlay_root: Path, dashboard_dir: Path
) -> list[str]:
    node = shutil.which("node")
    if not node:
        raise FileNotFoundError("Node.js is not available on PATH")
    return [
        node,
        str(overlay_root / "scripts" / "test-category-schema.cjs"),
        str(dashboard_dir),
    ]


def category_editor_state_harness_command(
    overlay_root: Path, dashboard_dir: Path
) -> list[str]:
    node = shutil.which("node")
    if not node:
        raise FileNotFoundError("Node.js is not available on PATH")
    return [
        node,
        str(overlay_root / "scripts" / "test-category-editor-state.cjs"),
        str(dashboard_dir),
    ]


def strip_comments(content: str) -> str:
    result: list[str] = []
    index = 0
    quote: str | None = None
    while index < len(content):
        character = content[index]
        next_character = content[index + 1] if index + 1 < len(content) else ""
        if quote is not None:
            result.append(character)
            if character == "\\" and index + 1 < len(content):
                index += 1
                result.append(content[index])
            elif character == quote:
                quote = None
            index += 1
            continue
        if character in ('"', "'", "`"):
            quote = character
            result.append(character)
            index += 1
            continue
        if character == "/" and next_character == "/":
            while index < len(content) and content[index] != "\n":
                result.append(" ")
                index += 1
            continue
        if character == "/" and next_character == "*":
            result.extend((" ", " "))
            index += 2
            while index < len(content) - 1:
                if content[index] == "*" and content[index + 1] == "/":
                    result.extend((" ", " "))
                    index += 2
                    break
                result.append("\n" if content[index] == "\n" else " ")
                index += 1
            continue
        result.append(character)
        index += 1
    return "".join(result)


def extract_balanced(content: str, start: int, opening: str, closing: str) -> str | None:
    depth = 0
    quote: str | None = None
    for index in range(start, len(content)):
        character = content[index]
        if quote is not None:
            if character == "\\":
                continue
            if character == quote:
                quote = None
            continue
        if character in ('"', "'", "`"):
            quote = character
        elif character == opening:
            depth += 1
        elif character == closing:
            depth -= 1
            if depth == 0:
                return content[start : index + 1]
    return None


def extract_named_array(content: str, name: str) -> str | None:
    code = strip_comments(content)
    match = re.search(
        rf"\bconst\s+{re.escape(name)}(?:\s*:\s*[^=]+)?\s*=\s*\[",
        code,
    )
    if match is None:
        return None
    start = match.end() - 1
    return extract_balanced(code, start, "[", "]")


def extract_named_function_body(content: str, name: str) -> str | None:
    code = strip_comments(content)
    match = re.search(rf"\bfunction\s+{re.escape(name)}\s*\(", code)
    if match is None:
        return None
    start = code.find("{", match.end())
    if start == -1:
        return None
    return extract_balanced(code, start, "{", "}")


def extract_object_initializers(array_content: str) -> list[str]:
    objects: list[str] = []
    index = 0
    while index < len(array_content):
        if array_content[index] == "{":
            item = extract_balanced(array_content, index, "{", "}")
            if item is None:
                return []
            objects.append(item)
            index += len(item)
        else:
            index += 1
    return objects


def string_property(item: str, name: str) -> str | None:
    match = re.search(rf'\b{re.escape(name)}\s*:\s*"([^"]*)"', item)
    return match.group(1) if match is not None else None


def verify_nav_items(
    array_content: str | None,
    array_name: str,
    expected_titles: list[str],
    expected_badge: str | None,
) -> str | None:
    if array_content is None:
        return f"main-nav missing {array_name} initializer"
    items = extract_object_initializers(array_content)
    titles = [string_property(item, "title") for item in items]
    if titles != expected_titles:
        return f"main-nav {array_name} must contain only " + " and ".join(expected_titles)
    for item, title in zip(items, expected_titles, strict=True):
        badge = string_property(item, "badge")
        if expected_badge is None and badge is not None:
            if badge == "SELF-HOSTED":
                return "main-nav must not contain SELF-HOSTED badges"
            return f"main-nav {title} must not have a badge"
        if expected_badge is not None and badge != expected_badge:
            return f"main-nav {title} must have a {expected_badge} badge"
    return None


def verify_main_nav_groups(main_nav_content: str) -> str | None:
    memory_tools_error = verify_nav_items(
        extract_named_array(main_nav_content, "MEMORY_TOOL_ITEMS"),
        "MEMORY_TOOL_ITEMS",
        ["Categories", "Export"],
        None,
    )
    if memory_tools_error is not None:
        return memory_tools_error
    cloud_features_error = verify_nav_items(
        extract_named_array(main_nav_content, "CLOUD_FEATURE_ITEMS"),
        "CLOUD_FEATURE_ITEMS",
        ["Webhooks", "Analytics"],
        "PRO",
    )
    if cloud_features_error is not None:
        return cloud_features_error
    for group, items in (
        ("memory-tools", "MEMORY_TOOL_ITEMS"),
        ("cloud-features", "CLOUD_FEATURE_ITEMS"),
    ):
        binding_error = verify_rendered_nav_binding(main_nav_content, group, items)
        if binding_error is not None:
            return binding_error
    return None


def verify_categories_page(dashboard_dir: Path) -> str | None:
    page_content = (dashboard_dir / CATEGORIES_PAGE).read_text()
    drawer_content = (dashboard_dir / CATEGORY_EDITOR_DRAWER).read_text()
    if "CategoryEditorDrawer" not in page_content:
        return "Categories page missing CategoryEditorDrawer"
    if "Create category" not in page_content:
        return "Categories page missing Create category action"
    if "Advanced schema" not in drawer_content:
        return "Categories editor missing Advanced schema fallback"

    categories_content = page_content + drawer_content
    if "Schema JSON" in categories_content:
        return "Categories must not present Schema JSON as the primary editor"
    if "SELF-HOSTED" in categories_content:
        return "Categories must not contain SELF-HOSTED copy"
    return None


def extract_export_format_tag(export_content: str, format_name: str) -> str | None:
    marker = "<RadioGroupItem"
    index = 0
    while True:
        start = export_content.find(marker, index)
        if start == -1:
            return None
        tag = extract_balanced(
            export_content,
            start,
            "<",
            ">",
        )
        if tag is None:
            return None
        if re.search(rf'\bvalue\s*=\s*"{re.escape(format_name)}"', tag):
            return tag
        index = start + len(tag)


def extract_jsx_component_tags(content: str, component: str) -> list[str]:
    code = strip_comments(content)
    marker = f"<{component}"
    tags: list[str] = []
    index = 0
    while True:
        start = code.find(marker, index)
        if start == -1:
            return tags
        following_index = start + len(marker)
        if following_index < len(code) and not code[following_index].isspace():
            index = following_index
            continue
        tag = extract_balanced(code, start, "<", ">")
        if tag is None:
            return tags
        tags.append(tag)
        index = start + len(tag)


def verify_rendered_nav_binding(
    main_nav_content: str, group: str, items: str
) -> str | None:
    tags = extract_jsx_component_tags(main_nav_content, "NavigationItems")
    matching_tags = [
        tag
        for tag in tags
        if re.search(rf'\bgroup\s*=\s*"{re.escape(group)}"', tag)
    ]
    if len(matching_tags) != 1:
        return f"main-nav must render one {group} NavigationItems binding"
    if (
        re.search(
            rf"\bitems\s*=\s*\{{\s*{re.escape(items)}\s*\}}",
            matching_tags[0],
        )
        is None
    ):
        return f"main-nav {group} must render items={{{items}}}"
    return None


def verify_disabled_export_format(export_content: str, format_name: str) -> str | None:
    tag = extract_export_format_tag(export_content, format_name)
    if tag is None:
        return f'Export page missing {format_name.upper()} format option'
    plain_disabled = re.search(r"(?:^|\s)disabled(?=\s|/|>)", tag)
    explicit_true = re.search(
        r"(?:^|\s)disabled\s*=\s*\{\s*true\s*\}(?=\s|/|>)",
        tag,
    )
    if plain_disabled is None and explicit_true is None:
        return f"Export {format_name.upper()} format must use disabled or disabled={{true}}"
    return None


def verify_export_page(dashboard_dir: Path) -> str | None:
    export_content = (dashboard_dir / EXPORT_PAGE).read_text()
    if 'value="json"' not in export_content or 'format: "json"' not in export_content:
        return "Export page must remain JSON-only"
    for format_name in ("csv", "pydantic"):
        format_error = verify_disabled_export_format(export_content, format_name)
        if format_error is not None:
            return format_error
    if export_content.count("Coming soon") < 2:
        return "Export page missing Coming soon labels for future formats"
    if "SELF-HOSTED" in export_content:
        return "Export page must not contain SELF-HOSTED copy"
    return None


def verify_proxy_contract(dashboard_dir: Path) -> str | None:
    proxy_content = (dashboard_dir / SIDECAR_PROXY).read_text()
    route_content = (dashboard_dir / SIDECAR_ROUTE).read_text()
    collection_function = extract_named_function_body(
        proxy_content, "isProjectCategoriesPath"
    )
    if (
        collection_function is None
        or re.search(r'\bmethod\s*===\s*"POST"', collection_function) is None
    ):
        return "sidecar proxy missing category collection POST support"
    item_function = extract_named_function_body(
        proxy_content, "isProjectCategoryItemPath"
    )
    if item_function is None:
        return "sidecar proxy missing category item route recognition"
    for method in ("PATCH", "DELETE"):
        if re.search(rf'\bmethod\s*===\s*"{method}"', item_function) is None:
            return f"sidecar proxy missing category item {method} support"
    if 'const METHODS_WITH_BODY = new Set(["POST", "PUT", "PATCH"]);' not in proxy_content:
        return "sidecar proxy METHODS_WITH_BODY must include PATCH"
    for method in ("PATCH", "DELETE"):
        if (
            re.search(
                rf"\bexport\s+const\s+{method}\s*=\s*proxy\s*;",
                strip_comments(route_content),
            )
            is None
        ):
            return f"sidecar route missing {method} handler"
    return None


def main() -> int:
    if len(sys.argv) != 2:
        print("usage: verify-dashboard-overlay <dashboard-dir>", file=sys.stderr)
        return 2

    overlay_root = Path(__file__).resolve().parents[1]
    dashboard_dir = Path(sys.argv[1]).resolve()

    manifest = json.loads((overlay_root / "manifest.json").read_text())
    for relative in manifest["files"]:
        target = dashboard_dir / relative
        if not target.exists():
            print(f"missing manifest file: {relative}", file=sys.stderr)
            return 1

    for relative in LOCKED_TARGETS:
        content = (dashboard_dir / relative).read_text()
        if "LockedPage" in content:
            print(f"{relative} still imports or renders LockedPage", file=sys.stderr)
            return 1

    checks = (
        verify_main_nav_groups((dashboard_dir / MAIN_NAV).read_text()),
        verify_categories_page(dashboard_dir),
        verify_export_page(dashboard_dir),
        verify_proxy_contract(dashboard_dir),
    )
    for error in checks:
        if error is not None:
            print(error, file=sys.stderr)
            return 1

    if os.environ.get("MEM0_DASHBOARD_OVERLAY_SKIP_TYPECHECK") == "1":
        return 0

    try:
        subprocess.run(typecheck_command(dashboard_dir), cwd=dashboard_dir, check=True)
        subprocess.run(
            proxy_harness_command(overlay_root, dashboard_dir),
            cwd=dashboard_dir,
            check=True,
        )
        subprocess.run(
            category_schema_harness_command(overlay_root, dashboard_dir),
            cwd=dashboard_dir,
            check=True,
        )
        subprocess.run(
            category_editor_state_harness_command(overlay_root, dashboard_dir),
            cwd=dashboard_dir,
            check=True,
        )
    except FileNotFoundError as exc:
        print(str(exc), file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
