#!/usr/bin/env python3
import json
import shutil
import subprocess
import sys
from pathlib import Path

LOCKED_TARGETS = [
    "src/app/(root)/dashboard/categories/page.tsx",
    "src/app/(root)/dashboard/export/page.tsx",
]


def npm_exec_pnpm_package(dashboard_dir: Path) -> str:
    package_json = dashboard_dir / "package.json"
    if not package_json.exists():
        return "pnpm"

    package_data = json.loads(package_json.read_text())
    package_manager = package_data.get("packageManager")
    if isinstance(package_manager, str) and package_manager.startswith("pnpm@"):
        return package_manager
    return "pnpm"


def typecheck_command(dashboard_dir: Path) -> list[str]:
    if shutil.which("pnpm"):
        return ["pnpm", "typecheck"]
    if shutil.which("npm"):
        return [
            "npm",
            "exec",
            "--yes",
            npm_exec_pnpm_package(dashboard_dir),
            "--",
            "typecheck",
        ]
    raise FileNotFoundError("Neither pnpm nor npm is available on PATH")


def main() -> int:
    if len(sys.argv) != 2:
        print("usage: verify-dashboard-overlay <dashboard-dir>", file=sys.stderr)
        return 2

    overlay_root = Path(__file__).resolve().parents[1]
    dashboard_dir = Path(sys.argv[1]).resolve()

    manifest = json.loads((overlay_root / "manifest.json").read_text())
    for relative in manifest["files"]:
        target = dashboard_dir / relative
        if not target.exists():
            print(f"missing manifest file: {relative}", file=sys.stderr)
            return 1

    for relative in LOCKED_TARGETS:
        content = (dashboard_dir / relative).read_text()
        if "LockedPage" in content:
            print(f"{relative} still imports or renders LockedPage", file=sys.stderr)
            return 1

    try:
        subprocess.run(typecheck_command(dashboard_dir), cwd=dashboard_dir, check=True)
    except FileNotFoundError as exc:
        print(str(exc), file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
