#!/usr/bin/env python3
import json
import os
import shutil
import subprocess
import sys
from pathlib import Path

LOCKED_TARGETS = [
    "src/app/(root)/dashboard/categories/page.tsx",
    "src/app/(root)/dashboard/export/page.tsx",
]
MAIN_NAV = "src/app/(root)/dashboard/components/main-nav.tsx"
CATEGORIES_PAGE = "src/app/(root)/dashboard/categories/page.tsx"
CATEGORY_EDITOR_DRAWER = (
    "src/app/(root)/dashboard/categories/category-editor-drawer.tsx"
)
EXPORT_PAGE = "src/app/(root)/dashboard/export/page.tsx"
SIDECAR_PROXY = "src/utils/sidecar-proxy.ts"
SIDECAR_ROUTE = "src/app/api/sidecar/[...path]/route.ts"
DEFAULT_PNPM_PACKAGE = "pnpm@10.34.2"


def npm_exec_pnpm_package(dashboard_dir: Path) -> str:
    package_json = dashboard_dir / "package.json"
    if not package_json.exists():
        return DEFAULT_PNPM_PACKAGE

    package_data = json.loads(package_json.read_text())
    package_manager = package_data.get("packageManager")
    if isinstance(package_manager, str) and package_manager.startswith("pnpm@"):
        return package_manager
    return DEFAULT_PNPM_PACKAGE


def typecheck_command(dashboard_dir: Path) -> list[str]:
    if shutil.which("pnpm"):
        return ["pnpm", "typecheck"]
    if shutil.which("npm"):
        return [
            "npm",
            "exec",
            "--yes",
            npm_exec_pnpm_package(dashboard_dir),
            "--",
            "typecheck",
        ]
    raise FileNotFoundError("Neither pnpm nor npm is available on PATH")


def proxy_harness_command(overlay_root: Path, dashboard_dir: Path) -> list[str]:
    node = shutil.which("node")
    if not node:
        raise FileNotFoundError("Node.js is not available on PATH")
    return [
        node,
        str(overlay_root / "scripts" / "test-sidecar-proxy.cjs"),
        str(dashboard_dir),
    ]


def category_schema_harness_command(
    overlay_root: Path, dashboard_dir: Path
) -> list[str]:
    node = shutil.which("node")
    if not node:
        raise FileNotFoundError("Node.js is not available on PATH")
    return [
        node,
        str(overlay_root / "scripts" / "test-category-schema.cjs"),
        str(dashboard_dir),
    ]


def category_editor_state_harness_command(
    overlay_root: Path, dashboard_dir: Path
) -> list[str]:
    node = shutil.which("node")
    if not node:
        raise FileNotFoundError("Node.js is not available on PATH")
    return [
        node,
        str(overlay_root / "scripts" / "test-category-editor-state.cjs"),
        str(dashboard_dir),
    ]


def item_block(content: str, title: str) -> str | None:
    marker = f'title: "{title}"'
    start = content.find(marker)
    if start == -1:
        return None
    end = content.find('title: "', start + len(marker))
    return content[start:] if end == -1 else content[start:end]


def nav_titles(content: str) -> list[str]:
    return [part.split('"', 1)[0] for part in content.split('title: "')[1:]]


def verify_main_nav_groups(main_nav_content: str) -> str | None:
    memory_tools_start = main_nav_content.find("MEMORY TOOLS")
    if memory_tools_start == -1:
        return "main-nav missing MEMORY TOOLS group"

    cloud_features_start = main_nav_content.find("CLOUD FEATURES", memory_tools_start)
    if cloud_features_start == -1:
        return "main-nav missing CLOUD FEATURES group"

    account_start = main_nav_content.find("ACCOUNT", cloud_features_start)
    if account_start == -1:
        return "main-nav missing ACCOUNT group"

    memory_tools = main_nav_content[memory_tools_start:cloud_features_start]
    cloud_features = main_nav_content[cloud_features_start:account_start]
    if "SELF-HOSTED" in main_nav_content:
        return "main-nav must not contain SELF-HOSTED badges"

    if nav_titles(memory_tools) != ["Categories", "Export"]:
        return "main-nav MEMORY TOOLS must contain only Categories and Export"
    if nav_titles(cloud_features) != ["Webhooks", "Analytics"]:
        return "main-nav CLOUD FEATURES must contain only Webhooks and Analytics"

    for title in ("Categories", "Export"):
        if f'title: "{title}"' not in memory_tools:
            return f'main-nav MEMORY TOOLS missing item: "{title}"'
        if f'title: "{title}"' in cloud_features:
            return f'main-nav {title} must not be in CLOUD FEATURES'
        block = item_block(memory_tools, title)
        if block is not None and "badge:" in block:
            return f'main-nav {title} must not have a badge'

    for title in ("Webhooks", "Analytics"):
        if f'title: "{title}"' in memory_tools:
            return f'main-nav {title} must not be in MEMORY TOOLS'
        if f'title: "{title}"' not in cloud_features:
            return f'main-nav CLOUD FEATURES missing item: "{title}"'
        block = item_block(cloud_features, title)
        if block is None or 'badge: "PRO"' not in block:
            return f'main-nav {title} must have a PRO badge'

    return None


def verify_categories_page(dashboard_dir: Path) -> str | None:
    page_content = (dashboard_dir / CATEGORIES_PAGE).read_text()
    drawer_content = (dashboard_dir / CATEGORY_EDITOR_DRAWER).read_text()
    if "CategoryEditorDrawer" not in page_content:
        return "Categories page missing CategoryEditorDrawer"
    if "Create category" not in page_content:
        return "Categories page missing Create category action"
    if "Advanced schema" not in drawer_content:
        return "Categories editor missing Advanced schema fallback"

    categories_content = page_content + drawer_content
    if "Schema JSON" in categories_content:
        return "Categories must not present Schema JSON as the primary editor"
    if "SELF-HOSTED" in categories_content:
        return "Categories must not contain SELF-HOSTED copy"
    return None


def verify_disabled_export_format(export_content: str, format_name: str) -> str | None:
    marker = f'<RadioGroupItem value="{format_name}"'
    start = export_content.find(marker)
    if start == -1:
        return f'Export page missing {format_name.upper()} format option'
    end = export_content.find("/>", start)
    if end == -1 or "disabled" not in export_content[start:end]:
        return f'Export {format_name.upper()} format must remain disabled'
    return None


def verify_export_page(dashboard_dir: Path) -> str | None:
    export_content = (dashboard_dir / EXPORT_PAGE).read_text()
    if 'value="json"' not in export_content or 'format: "json"' not in export_content:
        return "Export page must remain JSON-only"
    for format_name in ("csv", "pydantic"):
        format_error = verify_disabled_export_format(export_content, format_name)
        if format_error is not None:
            return format_error
    if export_content.count("Coming soon") < 2:
        return "Export page missing Coming soon labels for future formats"
    if "SELF-HOSTED" in export_content:
        return "Export page must not contain SELF-HOSTED copy"
    return None


def verify_proxy_contract(dashboard_dir: Path) -> str | None:
    proxy_content = (dashboard_dir / SIDECAR_PROXY).read_text()
    route_content = (dashboard_dir / SIDECAR_ROUTE).read_text()
    if (
        "isProjectCategoriesPath" not in proxy_content
        or 'method === "POST"' not in proxy_content
    ):
        return "sidecar proxy missing category collection POST support"
    if "isProjectCategoryItemPath" not in proxy_content:
        return "sidecar proxy missing category item route recognition"
    for method in ("PATCH", "DELETE"):
        if f'method === "{method}"' not in proxy_content:
            return f"sidecar proxy missing category item {method} support"
    if 'const METHODS_WITH_BODY = new Set(["POST", "PUT", "PATCH"]);' not in proxy_content:
        return "sidecar proxy METHODS_WITH_BODY must include PATCH"
    for method in ("PATCH", "DELETE"):
        if f"export const {method} = proxy;" not in route_content:
            return f"sidecar route missing {method} handler"
    return None


def main() -> int:
    if len(sys.argv) != 2:
        print("usage: verify-dashboard-overlay <dashboard-dir>", file=sys.stderr)
        return 2

    overlay_root = Path(__file__).resolve().parents[1]
    dashboard_dir = Path(sys.argv[1]).resolve()

    manifest = json.loads((overlay_root / "manifest.json").read_text())
    for relative in manifest["files"]:
        target = dashboard_dir / relative
        if not target.exists():
            print(f"missing manifest file: {relative}", file=sys.stderr)
            return 1

    for relative in LOCKED_TARGETS:
        content = (dashboard_dir / relative).read_text()
        if "LockedPage" in content:
            print(f"{relative} still imports or renders LockedPage", file=sys.stderr)
            return 1

    checks = (
        verify_main_nav_groups((dashboard_dir / MAIN_NAV).read_text()),
        verify_categories_page(dashboard_dir),
        verify_export_page(dashboard_dir),
        verify_proxy_contract(dashboard_dir),
    )
    for error in checks:
        if error is not None:
            print(error, file=sys.stderr)
            return 1

    if os.environ.get("MEM0_DASHBOARD_OVERLAY_SKIP_TYPECHECK") == "1":
        return 0

    try:
        subprocess.run(typecheck_command(dashboard_dir), cwd=dashboard_dir, check=True)
        subprocess.run(
            proxy_harness_command(overlay_root, dashboard_dir),
            cwd=dashboard_dir,
            check=True,
        )
        subprocess.run(
            category_schema_harness_command(overlay_root, dashboard_dir),
            cwd=dashboard_dir,
            check=True,
        )
        subprocess.run(
            category_editor_state_harness_command(overlay_root, dashboard_dir),
            cwd=dashboard_dir,
            check=True,
        )
    except FileNotFoundError as exc:
        print(str(exc), file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
